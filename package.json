{
  "name": "unexpectedly",
  "version": "3.0.3",
  "description": "Keep a bunch of test cases in a file, with their expected results",
  "main": "index.js",
  "type": "module",
  "files": [
    "index.js",
    "runner.js",
    "testFile.peg.js",
    "utils.js",
    "version.js",
    "vendor/",
    "bin/"
  ],
  "scripts": {
    "build": "peggy -o testFile.peg.js --format es testFile.peggy",
    "pretest": "npm run build",
    "test": "c8 npm run runtests",
    "runtests": "mocha && bin/unexpectedly.js test test/pkg_mjs/test test/pkg_cjs/test",
    "lint": "eslint .",
    "ci": "npm run test && npm run lint",
    "clean": "rimraf coverage testFile.peg.js",
    "version": "package-extract -s -o version.js && git add version.js"
  },
  "bin": {
    "unexpectedly": "bin/unexpectedly.js"
  },
  "keywords": [
    "test",
    "case",
    "testcase",
    "actual",
    "expected",
    "mocha",
    "harness"
  ],
  "author": "Joe Hildebrand <joe-github@cursive.net>",
  "repository": {
    "type": "git",
    "url": "http://github.com/hildjj/unexpectedly.git"
  },
  "license": "MPL-2.0",
  "dependencies": {
    "@peggyjs/from-mem": "3.1.3",
    "commander": "14.0.3",
    "mocha": "^11.7.5"
  },
  "devDependencies": {
    "@cto.af/eslint-config": "6.2.5",
    "eslint": "^10.0.2",
    "eslint-plugin-mocha": "^11.2.0",
    "package-extract": "3.1.5",
    "peggy": "^5.1.0",
    "rimraf": "6.1.3",
    "superc8": "^12.2.4",
    "zx": "8.8.5"
  },
  "packageManager": "pnpm@10.30.3",
  "pnpm": {
    "overrides": {
      "mocha@11.7.5>diff": "8.0.3",
      "mocha@11.7.5>serialize-javascript": "7.0.4"
    }
  },
  "engines": {
    "node": ">=20"
  }
}
